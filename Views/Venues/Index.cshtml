@model AdminPortal.Models.PagedResult<AdminPortal.Models.VenueDto>
@{ ViewData["Title"] = "Sedes"; }

<div class="page-header">
    <div>
        <h1 class="page-title">Sedes</h1>
        <p class="page-desc">Espacios donde se realizan los eventos</p>
    </div>
    <button class="btn-primary" onclick="document.getElementById('createModal').classList.add('open')">+ Nueva sede</button>
</div>

@if (Model == null || !Model.Items.Any())
{
    <div class="empty-state">
        <div class="empty-icon">◫</div>
        <p>No hay sedes registradas.</p>
    </div>
}
else
{
    <div class="table-card">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Nombre</th><th>Ciudad</th><th>Dirección</th><th>Capacidad</th><th>Estado</th><th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var v in Model.Items)
                {
                    <tr>
                        <td class="font-medium">@v.Name</td>
                        <td>@v.City</td>
                        <td class="text-muted">@v.Address</td>
                        <td>@v.Capacity.ToString("N0")</td>
                        <td><span class="badge @(v.IsActive ? "badge-active" : "badge-inactive")">@(v.IsActive ? "Activa" : "Inactiva")</span></td>
                        <td>
                            <form method="post" action="/Venues/Delete/@v.Id" style="display:inline" onsubmit="return confirm('¿Eliminar esta sede?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-sm btn-delete">Eliminar</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- Modal -->
<div id="createModal" class="modal-overlay" onclick="if(event.target===this)this.classList.remove('open')">
    <div class="modal-box">
        <div class="modal-header">
            <h2>Nueva sede</h2>
            <button class="modal-close" onclick="document.getElementById('createModal').classList.remove('open')">✕</button>
        </div>
        <form method="post" action="/Venues/Create">
            @Html.AntiForgeryToken()
            <div class="field-group">
                <label class="field-label">Nombre *</label>
                <input type="text" name="Name" class="field-input" placeholder="Teatro Principal" required/>
            </div>
            <div class="field-group">
                <label class="field-label">Ciudad *</label>
                <input type="text" name="City" class="field-input" placeholder="Medellín" required/>
            </div>
            <div class="field-group">
                <label class="field-label">Dirección *</label>
                <input type="text" name="Address" class="field-input" placeholder="Calle 100 # 50-20" required/>
            </div>
            <div class="field-group">
                <label class="field-label">Capacidad *</label>
                <input type="number" name="Capacity" class="field-input" placeholder="500" min="1" required/>
            </div>
            <div class="form-actions">
                <button type="button" class="btn-secondary" onclick="document.getElementById('createModal').classList.remove('open')">Cancelar</button>
                <button type="submit" class="btn-primary">Crear sede</button>
            </div>
        </form>
    </div>
</div>
