@model AdminPortal.Models.CustomerEditViewModel
@{ ViewData["Title"] = "Editar cliente"; }

<div class="page-header">
    <div>
        <h1 class="page-title">Editar cliente</h1>
        <p class="page-desc">@Model.User.Email · Roles: @string.Join(", ", Model.User.Roles)</p>
    </div>
    <a asp-action="Index" class="btn-secondary">← Volver</a>
</div>

@if (ViewBag.Error != null)
{
    <div class="toast toast-error">✗ @ViewBag.Error</div>
}

<div class="form-card">
    <form method="post" asp-action="Edit" asp-route-id="@Model.User.Id">
        @Html.AntiForgeryToken()
        <div class="field-group">
            <label class="field-label">Nombre completo *</label>
            <input type="text" name="request.FullName" class="field-input"
                   value="@Model.Request.FullName" required />
        </div>
        <div class="field-group">
            <label class="field-label">Email *</label>
            <input type="email" name="request.Email" class="field-input"
                   value="@Model.Request.Email" required />
        </div>
        <div class="field-group">
            <label class="field-label">Estado</label>
            <select name="request.IsActive" class="field-input">
                <option value="true"  @(Model.Request.IsActive ? "selected" : "")>Activo</option>
                <option value="false" @(!Model.Request.IsActive ? "selected" : "")>Inactivo</option>
            </select>
        </div>
        <div class="form-actions">
            <a asp-action="Index" class="btn-secondary">Cancelar</a>
            <button type="submit" class="btn-primary">Guardar cambios</button>
        </div>
    </form>
</div>
