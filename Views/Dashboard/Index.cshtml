@model admin_tickets.Models.DashboardDto
@{ ViewData["Title"] = "Dashboard"; }

<div class="page-header">
    <div>
        <h1 class="page-title">Dashboard</h1>
        <p class="page-desc">Resumen ejecutivo del teatro</p>
    </div>
    <div class="page-date">@DateTime.Now.ToString("dddd, d 'de' MMMM yyyy", new System.Globalization.CultureInfo("es-CO"))</div>
</div>

@if (Model == null)
{
    <div class="empty-state">
        <div class="empty-icon">◉</div>
        <p>No se pudieron cargar las métricas. Verifica la conexión con la API.</p>
    </div>
}
else
{
    <div class="kpi-grid">
        <div class="kpi-card kpi-primary">
            <div class="kpi-label">Ingresos totales</div>
            <div class="kpi-value">$@Model.TotalRevenue.ToString("N0")</div>
            <div class="kpi-sub">Acumulado histórico</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">Boletas vendidas</div>
            <div class="kpi-value">@Model.TotalTicketsSold.ToString("N0")</div>
            <div class="kpi-sub">Total histórico</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">Eventos activos</div>
            <div class="kpi-value">@Model.ActiveEvents</div>
            <div class="kpi-sub">En cartelera</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">Ocupación promedio</div>
            <div class="kpi-value">@Model.AverageOccupancyPct.ToString("F1")%</div>
            <div class="kpi-sub">Índice global</div>
        </div>
        <div class="kpi-card kpi-accent">
            <div class="kpi-label">Ingresos hoy</div>
            <div class="kpi-value">$@Model.TodayRevenue.ToString("N0")</div>
            <div class="kpi-sub">@Model.TodayTicketsSold boletas</div>
        </div>
    </div>

    <div class="dashboard-grid">
        <div class="card chart-card">
            <div class="card-header">
                <h2 class="card-title">Ingresos por día</h2>
            </div>
            <div class="chart-wrap">
                <canvas id="revenueChart"></canvas>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h2 class="card-title">Top eventos</h2>
            </div>
            @if (Model.TopEvents.Any())
            {
                <div class="top-events">
                    @foreach (var (ev, i) in Model.TopEvents.Select((e,i) => (e,i)))
                    {
                        <div class="top-event-row">
                            <div class="rank-badge">@(i+1)</div>
                            <div class="event-info">
                                <div class="event-name">@ev.EventName</div>
                                <div class="event-meta">@ev.TicketsSold boletas · @ev.OccupancyPct.ToString("F0")% ocupación</div>
                            </div>
                            <div class="event-revenue">$@ev.Revenue.ToString("N0")</div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="empty-text">Sin datos de eventos aún.</p>
            }
        </div>
    </div>

    @if (Model.RevenueByDay.Any())
    {
        <script>
        window._chartLabels = [@Html.Raw(string.Join(",", Model.RevenueByDay.Select(d => $"\"{d.Date:MMM d}\"")))];
        window._chartData   = [@string.Join(",", Model.RevenueByDay.Select(d => d.Revenue))];
        </script>
    }
}

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
(function() {
    var labels = window._chartLabels || [];
    var data   = window._chartData   || [];
    if (!labels.length) return;
    var ctx = document.getElementById('revenueChart');
    if (!ctx) return;
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: labels,
            datasets: [{
                label: 'Ingresos',
                data: data,
                borderColor: '#FD7B41',
                backgroundColor: 'rgba(253,123,65,0.12)',
                borderWidth: 2.5,
                pointBackgroundColor: '#FD7B41',
                pointRadius: 4,
                tension: 0.4,
                fill: true
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                x: { grid: { color: 'rgba(221,220,219,0.15)' }, ticks: { color: '#DDDCDB', font: { family: 'DM Sans' } } },
                y: { grid: { color: 'rgba(221,220,219,0.1)' }, ticks: { color: '#DDDCDB', font: { family: 'DM Sans' }, callback: v => '$' + v.toLocaleString() } }
            }
        }
    });
})();
</script>
}
