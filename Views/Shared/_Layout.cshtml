<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Kepler Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="app-body">
@{
    var token = Context.Session.GetString("AccessToken");
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString();
}
@if (token != null)
{
    <aside class="sidebar">
        <div class="sidebar-brand">
            <span class="brand-icon">◈</span>
            <div>
                <div class="brand-name">KEPLER</div>
                <div class="brand-sub">Panel de control</div>
            </div>
        </div>
        <nav class="sidebar-nav">
            <a href="/Dashboard/Index" class="nav-item @(ctrl == "Dashboard" ? "active" : "")">
                <span class="nav-icon">◉</span><span>Dashboard</span>
            </a>
            <a href="/Events/index" class="nav-item @(ctrl == "Events" ? "active" : "")">
                <span class="nav-icon">◈</span><span>Eventos</span>
            </a>
            <a href="/Showtimes/Index" class="nav-item @(ctrl == "Showtimes" ? "active" : "")">
                <span class="nav-icon">◷</span><span>Funciones</span>
            </a>
            <a href="/Venues/Index" class="nav-item @(ctrl == "Venues" ? "active" : "")">
                <span class="nav-icon">◫</span><span>Sedes</span>
            </a>
            <a href="/Employees/Index" class="nav-item @(ctrl == "Employees" ? "active" : "")">
                <span class="nav-icon">◎</span><span>Empleados</span>
            </a>
        </nav>
        <div class="sidebar-footer">
            <div class="user-info">
                <div class="user-avatar">@(Context.Session.GetString("UserEmail")?[0].ToString().ToUpper() ?? "A")</div>
                <div class="user-details">
                    <div class="user-email">@(Context.Session.GetString("UserEmail") ?? "Admin")</div>
                    <div class="user-role">Administrador</div>
                </div>
            </div>
            <form method="post" action="/Auth/Logout" style="margin:0">
                @Html.AntiForgeryToken()
                <button type="submit" class="logout-btn" title="Cerrar sesión">⏻</button>
            </form>
        </div>
    </aside>
    <main class="main-content">
        @if (TempData["Success"] != null)
        {
            <div class="toast toast-success">✓ @TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="toast toast-error">✗ @TempData["Error"]</div>
        }
        @RenderBody()
    </main>
}
else
{
    @RenderBody()
}
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
