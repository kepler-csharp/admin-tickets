@using AdminPortal.Models
@using Microsoft.AspNetCore.Mvc.Rendering
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model LoginDto
@{
    Layout = null;
    ViewData["Title"] = "Iniciar sesión";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width,initial-scale=1"/>
    <title>Kepler Admin — Login</title>
    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:opsz,wght@9..40,300;9..40,400&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="/css/site.css"/>
</head>
<body class="login-body">
    <div class="login-bg">
        <div class="login-orb orb1"></div>
        <div class="login-orb orb2"></div>
        <div class="login-grid"></div>
    </div>

    <div class="login-container">
        <div class="login-brand">
            <span class="login-icon">◈</span>
            <h1 class="login-title">KEPLER</h1>
            <p class="login-subtitle">Portal de Administración</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="login-error">@ViewBag.Error</div>
        }

        <form method="post" class="login-form">
            @Html.AntiForgeryToken()
            <div class="field-group">
                <label class="field-label">Correo electrónico</label>
                <input type="email" name="Email" class="field-input"
                       placeholder="admin@kepler.com" required autocomplete="email"/>
            </div>
            <div class="field-group">
                <label class="field-label">Contraseña</label>
                <input type="password" name="Password" class="field-input"
                       placeholder="••••••••" required autocomplete="current-password"/>
            </div>
            <button type="submit" class="login-btn">Ingresar al panel</button>
        </form>

        <p class="login-footer">Teatro Kepler &copy; @DateTime.Now.Year</p>
    </div>
</body>
</html>
