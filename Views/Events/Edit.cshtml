@model AdminPortal.Models.EventFormViewModel
@{ ViewData["Title"] = "Editar Evento"; }

<div class="page-header">
    <div>
        <a href="/Events" class="back-link">← Volver a eventos</a>
        <h1 class="page-title">Editar evento</h1>
    </div>
</div>

@if (ViewBag.Error != null)
{
    <div class="form-error-banner">@ViewBag.Error</div>
}

<div class="form-card">
    <form method="post" action="/Events/Edit/@Model.EditId">
        @Html.AntiForgeryToken()

        <div class="form-grid">
            <div class="field-group span-2">
                <label class="field-label">Nombre del evento *</label>
                <input type="text" name="Request.Name" value="@Model.Request.Name" class="field-input" required/>
            </div>
            <div class="field-group span-2">
                <label class="field-label">Descripción</label>
                <textarea name="Request.Description" class="field-input field-textarea">@Model.Request.Description</textarea>
            </div>
            <div class="field-group">
                <label class="field-label">Tipo</label>
                <select name="Request.Type" class="field-input">
                    @foreach (var t in Enum.GetValues<AdminPortal.Models.EventType>())
                    {
                        <option value="@((int)t)">@t</option>
                    }
                </select>
            </div>
            <div class="field-group">
                <label class="field-label">Duración (min)</label>
                <input type="number" name="Request.DurationMinutes" value="@Model.Request.DurationMinutes" class="field-input" min="1"/>
            </div>
            <div class="field-group span-2">
                <label class="field-label">Sede</label>
                <select name="Request.VenueId" class="field-input">
                    @foreach (var v in Model.Venues)
                    {
                        <option value="@v.Id">@v.Name — @v.City</option>
                    }
                </select>
            </div>
            <div class="field-group span-2">
                <label class="field-label">URL del póster</label>
                <input type="url" name="Request.PosterUrl" value="@Model.Request.PosterUrl" class="field-input"/>
            </div>
            <div class="field-group">
                <label class="field-label">Estado</label>
                <select name="Request.IsActive" class="field-input">
                    <option value="true">Activo</option>
                    <option value="false">Inactivo</option>
                </select>
            </div>
        </div>

        <div class="form-actions">
            <a asp-controller="Events" asp-action="Index" class="btn-secondary">Cancelar</a>
            <button type="submit" class="btn-primary">Guardar cambios</button>
        </div>
    </form>
</div>
