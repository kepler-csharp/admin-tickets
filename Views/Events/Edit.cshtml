@model admin_tickets.Models.EventFormViewModel
@{ ViewData["Title"] = "Editar evento"; }

<div class="page-header">
    <div>
        <h1 class="page-title">Editar evento</h1>
    </div>

    <a asp-action="Index" class="btn-secondary">
        ← Volver
    </a>
</div>

@if (ViewBag.Error != null)
{
    <div class="toast toast-error">
        ✗ @ViewBag.Error
    </div>
}

<div class="form-card">
    <form method="post"
          asp-action="Edit"
          asp-route-id="@Model.EditId">

        @Html.AntiForgeryToken()

        <div class="field-group">
            <label class="field-label">
                Nombre *
            </label>

            <input type="text"
                   name="request.Name"
                   class="field-input"
                   value="@Model.Request.Name"
                   required />
        </div>

        <div class="field-group">
            <label class="field-label">
                Descripción *
            </label>

            <textarea name="request.Description"
                      class="field-input"
                      rows="3"
                      required>@Model.Request.Description</textarea>
        </div>

        <div class="field-group">
            <label class="field-label">
                Sede *
            </label>

            <select name="request.VenueId"
                    class="field-input"
                    required>

                @foreach (var v in Model.Venues)
                {
                    <option value="@v.Id">
                        @v.Name — @v.City
                    </option>
                }
            </select>
        </div>

        <div class="field-group">
            <label class="field-label">
                Tipo *
            </label>

            <select name="request.Type" class="field-input">
                @foreach (var t in Enum.GetValues<admin_tickets.Models.EventType>())
                {
                    <option value="@((int)t)"
                            selected="@(Model.Request.Type == t)">
                        @t
                    </option>
                }
            </select>
        </div>

        <div class="field-group">
            <label class="field-label">
                Duración (minutos) *
            </label>

            <input type="number"
                   name="request.DurationMinutes"
                   class="field-input"
                   value="@Model.Request.DurationMinutes"
                   min="1"
                   required />
        </div>

        <div class="field-group">
            <label class="field-label">
                Estado
            </label>

            <select name="request.IsActive" class="field-input">
                <option value="true">Activo</option>
                <option value="false">Inactivo</option>
            </select>
        </div>

        <div class="form-actions">
            <a asp-action="Index" class="btn-secondary">
                Cancelar
            </a>

            <button type="submit" class="btn-primary">
                Guardar cambios
            </button>
        </div>
    </form>
</div>

<div class="form-card" style="margin-top:1.5rem">
    <h2 class="section-title">
        Imagen del evento
    </h2>

    @if (!string.IsNullOrEmpty(Model.Request.PosterUrl))
    {
        <img src="@Model.Request.PosterUrl"
             alt="Póster"
             style="max-height:160px;border-radius:8px;margin-bottom:1rem;" />
    }

    <form method="post"
          asp-action="UploadPhoto"
          asp-route-id="@Model.EditId"
          enctype="multipart/form-data">

        @Html.AntiForgeryToken()

        <div class="field-group">
            <label class="field-label">
                Subir nueva imagen
            </label>

            <input type="file"
                   name="file"
                   class="field-input"
                   accept="image/*"
                   required />
        </div>

        <button type="submit" class="btn-primary">
            Subir imagen
        </button>
    </form>
</div>