@model AdminPortal.Models.EventFormViewModel
@{ ViewData["Title"] = Model.EditId.HasValue ? "Editar Evento" : "Nuevo Evento"; }

<div class="page-header">
    <div>
        <a href="/Events" class="back-link">← Volver a eventos</a>
        <h1 class="page-title">@ViewData["Title"]</h1>
    </div>
</div>

@if (ViewBag.Error != null)
{
    <div class="form-error-banner">@ViewBag.Error</div>
}

<div class="form-card">
    <form method="post" action="/Events/Create">
        @Html.AntiForgeryToken()

        <div class="form-grid">
            <div class="field-group span-2">
                <label class="field-label">Nombre del evento *</label>
                <input type="text" name="Request.Name" value="@Model.Request.Name" class="field-input" placeholder="Ej: Hamlet — Temporada 2025" required/>
            </div>

            <div class="field-group span-2">
                <label class="field-label">Descripción</label>
                <textarea name="Request.Description" class="field-input field-textarea" placeholder="Describe el evento…">@Model.Request.Description</textarea>
            </div>

            <div class="field-group">
                <label class="field-label">Tipo de evento *</label>
                <select name="Request.Type" class="field-input" required>
                    @foreach (var t in Enum.GetValues<AdminPortal.Models.EventType>())
                    {
                        <option value="@((int)t)">@t</option>
                    }
                </select>
            </div>

            <div class="field-group">
                <label class="field-label">Duración (minutos) *</label>
                <input type="number" name="Request.DurationMinutes" value="@(Model.Request.DurationMinutes == 0 ? "" : Model.Request.DurationMinutes)" class="field-input" placeholder="120" min="1" required/>
            </div>

            <div class="field-group span-2">
                <label class="field-label">Sede *</label>
                <select name="Request.VenueId" class="field-input" required>
                    <option value="">— Selecciona una sede —</option>
                    @foreach (var v in Model.Venues)
                    {
                        <option value="@v.Id">@v.Name — @v.City (@v.Capacity sillas)</option>
                    }
                </select>
                @if (!Model.Venues.Any())
                {
                    <p class="field-hint">⚠ No hay sedes. <a href="/Venues">Crea una sede primero.</a></p>
                }
            </div>

            <div class="field-group span-2">
                <label class="field-label">URL del póster (imagen)</label>
                <input type="url" name="Request.PosterUrl" value="@Model.Request.PosterUrl" class="field-input" placeholder="https://…" />
                <p class="field-hint">URL pública de la imagen del evento.</p>
            </div>
        </div>

        <div class="form-actions">
            <a asp-controller="Events" asp-action="Index" class="btn-secondary">Cancelar</a>
            <button type="submit" class="btn-primary">Guardar evento</button>
        </div>
    </form>
</div>
