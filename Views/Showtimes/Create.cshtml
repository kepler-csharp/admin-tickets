@model admin_tickets.Models.ShowtimeFormViewModel
@{ ViewData["Title"] = "Nueva Función"; }

<div class="page-header">
    <div>
        <a href="/Showtimes" class="back-link">← Volver a funciones</a>
        <h1 class="page-title">Nueva función</h1>
    </div>
</div>

@if (ViewBag.Error != null)
{
    <div class="form-error-banner">@ViewBag.Error</div>
}

<div class="form-card">
    <form method="post" action="/Showtimes/Create">
        @Html.AntiForgeryToken()
        <input type="hidden" name="seatLayout" id="seatLayoutJson"/>

        <div class="form-grid">
            <div class="field-group span-2">
                <label class="field-label">Evento *</label>
                <select name="Request.EventId" class="field-input" required>
                    <option value="">— Selecciona un evento —</option>
                    @foreach (var ev in Model.Events)
                    {
                        <option value="@ev.Id">@ev.Name (@ev.VenueName)</option>
                    }
                </select>
            </div>
            <div class="field-group">
                <label class="field-label">Fecha y hora de inicio *</label>
                <input type="datetime-local" name="Request.StartTime" class="field-input" required/>
            </div>
            <div class="field-group">
                <label class="field-label">Precio base (COP) *</label>
                <input type="number" name="Request.BasePrice" class="field-input" placeholder="45000" min="0" step="1000" required/>
            </div>
        </div>

        <div class="section-divider">
            <span>Distribución de sillas</span>
        </div>

        <div id="seatBuilder" class="seat-builder">
            <div id="rowList"></div>
            <button type="button" class="btn-outline" onclick="addRow()">+ Agregar fila</button>
        </div>

        <div class="form-actions">
            <a asp-controller="Showtimes" asp-action="Index" class="btn-secondary">Cancelar</a>
            <button type="submit" class="btn-primary" onclick="serializeLayout()">Crear función</button>
        </div>
    </form>
</div>

@section Scripts {
<script>
var rows = [];
function addRow() {
    var id = Date.now();
    rows.push(id);
    var div = document.createElement('div');
    div.id = 'row-' + id;
    div.className = 'seat-row-builder';
    div.innerHTML = `
        <input type="text" class="field-input row-letter" placeholder="Fila (A, B…)" maxlength="3" style="width:80px"/>
        <input type="number" class="field-input row-count" placeholder="# sillas" min="1" style="width:110px"/>
        <select class="field-input row-type" style="width:130px">
            <option value="0">Standard</option>
            <option value="1">Premium</option>
            <option value="2">VIP</option>
        </select>
        <button type="button" class="btn-sm btn-delete" onclick="removeRow(${id})">✕</button>
    `;
    document.getElementById('rowList').appendChild(div);
}
function removeRow(id) {
    rows = rows.filter(r => r !== id);
    document.getElementById('row-' + id).remove();
}
function serializeLayout() {
    var layout = rows.map(id => {
        var el = document.getElementById('row-' + id);
        return {
            row: el.querySelector('.row-letter').value,
            seatCount: parseInt(el.querySelector('.row-count').value) || 0,
            type: parseInt(el.querySelector('.row-type').value)
        };
    }).filter(r => r.row && r.seatCount > 0);
    document.getElementById('seatLayoutJson').value = JSON.stringify(layout);
}
// Start with one row
addRow();
</script>
}
